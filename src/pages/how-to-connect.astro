---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="How to Connect — CreativeClaw">
  <!-- Nav (simplified for subpage) -->
  <nav class="sticky top-0 z-50 bg-cream/90 backdrop-blur-md border-b border-cream-dark/40">
    <div class="mx-auto max-w-[1200px] px-6 flex items-center justify-between h-16">
      <a href="/">
        <img src="/logo-with-text.png" alt="CreativeClaw" class="h-10" />
      </a>
      <a
        href="/"
        class="text-sm font-semibold text-charcoal-light hover:text-charcoal transition-colors"
      >
        &larr; Back to Home
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="px-4 md:px-6 pt-16 pb-12">
    <div class="mx-auto max-w-[800px] text-center">
      <h1 class="font-display text-4xl md:text-6xl tracking-tight text-charcoal mb-6">
        How to Connect
      </h1>
      <p class="text-lg md:text-xl text-charcoal-light max-w-[600px] mx-auto">
        Get CreativeClaw running in your favorite Claude environment in under a minute.
      </p>
    </div>
  </section>

  <!-- Claude Desktop / Cowork -->
  <section id="claude-desktop" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[800px]">
      <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-12">
        <!-- Header -->
        <div class="flex items-center gap-4 mb-10">
          <div class="w-12 h-12 rounded-xl bg-[#F4E8DC] flex items-center justify-center">
            <svg height="28" viewBox="0 0 24 24" width="28" xmlns="http://www.w3.org/2000/svg"><path d="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z" fill="#D97757" fill-rule="nonzero"></path></svg>
          </div>
          <div>
            <h2 class="font-display text-2xl md:text-3xl text-charcoal">Claude Desktop / Cowork</h2>
            <p class="text-sm text-charcoal-light mt-1">Connect via the Marketplace</p>
          </div>
        </div>

        <!-- Steps -->
        <ol class="space-y-6">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">1</span>
            <div>
              <p class="font-semibold text-charcoal">Open the Customize tab</p>
              <p class="text-charcoal-light text-sm mt-1">Click on <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Customize</span> in your Claude Desktop sidebar.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">2</span>
            <div>
              <p class="font-semibold text-charcoal">Add the Marketplace</p>
              <p class="text-charcoal-light text-sm mt-1">Click the <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">+</span> button next to <strong>Personal Plugins</strong>, then select <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Add Marketplace</span>.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">3</span>
            <div>
              <p class="font-semibold text-charcoal">Enter the Marketplace URL</p>
              <p class="text-charcoal-light text-sm mt-1">Type in:</p>
              <div class="mt-2 bg-charcoal rounded-xl px-4 py-3 font-mono text-sm text-white/90 overflow-x-auto">
                CreativeClawCo/creative-claw-marketplace
              </div>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">4</span>
            <div>
              <p class="font-semibold text-charcoal">Install the Plugin</p>
              <p class="text-charcoal-light text-sm mt-1">Click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">+</span> next to <strong>Personal Plugins</strong> again, then select <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Browse Plugins</span>.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">5</span>
            <div>
              <p class="font-semibold text-charcoal">Find CreativeClaw</p>
              <p class="text-charcoal-light text-sm mt-1">Search for <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">creative-claw</span> and install it.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">6</span>
            <div>
              <p class="font-semibold text-charcoal">Authenticate</p>
              <p class="text-charcoal-light text-sm mt-1">Click on <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">creative-claw-connector</span> and authenticate the connector by logging in with Gmail.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-green-ink text-sm font-semibold flex items-center justify-center mt-0.5">&#10003;</span>
            <div>
              <p class="font-semibold text-charcoal">You're ready to create!</p>
              <p class="text-charcoal-light text-sm mt-1">Start a new conversation and ask Claude to generate images, videos, audio, or 3D models.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Claude Code -->
  <section id="claude-code" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[800px]">
      <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-12">
        <!-- Header -->
        <div class="flex items-center gap-4 mb-10">
          <div class="w-12 h-12 rounded-xl bg-[#F4E8DC] flex items-center justify-center">
            <svg height="28" viewBox="0 0 24 24" width="28" xmlns="http://www.w3.org/2000/svg"><path clip-rule="evenodd" d="M20.998 10.949H24v3.102h-3v3.028h-1.487V20H18v-2.921h-1.487V20H15v-2.921H9V20H7.488v-2.921H6V20H4.487v-2.921H3V14.05H0V10.95h3V5h17.998v5.949zM6 10.949h1.488V8.102H6v2.847zm10.51 0H18V8.102h-1.49v2.847z" fill="#D97757" fill-rule="evenodd"></path></svg>
          </div>
          <div>
            <h2 class="font-display text-2xl md:text-3xl text-charcoal">Claude Code</h2>
            <p class="text-sm text-charcoal-light mt-1">Connect via the CLI</p>
          </div>
        </div>

        <!-- Steps -->
        <ol class="space-y-6">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">1</span>
            <div>
              <p class="font-semibold text-charcoal">Add the Marketplace</p>
              <p class="text-charcoal-light text-sm mt-1">Run this command in your terminal:</p>
              <div class="mt-2 bg-charcoal rounded-xl px-4 py-3 font-mono text-sm text-white/90 overflow-x-auto">
                <span class="text-white/40 select-none">$ </span>claude plugin marketplace add CreativeClawCo/creative-claw-marketplace
              </div>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">2</span>
            <div>
              <p class="font-semibold text-charcoal">Install the Plugin</p>
              <p class="text-charcoal-light text-sm mt-1">Install CreativeClaw from the marketplace:</p>
              <div class="mt-2 bg-charcoal rounded-xl px-4 py-3 font-mono text-sm text-white/90 overflow-x-auto">
                <span class="text-white/40 select-none">$ </span>claude plugin install creative-claw@creative-claw-marketplace
              </div>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">3</span>
            <div>
              <p class="font-semibold text-charcoal">Authenticate</p>
              <p class="text-charcoal-light text-sm mt-1">Authenticate the MCP that was added:</p>
              <div class="mt-2 bg-charcoal rounded-xl px-4 py-3 font-mono text-sm text-white/90 overflow-x-auto">
                <span class="text-white/40 select-none">$ </span>claude mcp auth creative-claw
              </div>
              <p class="text-charcoal-light text-sm mt-2">This will open your browser to log in with Gmail.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-green-ink text-sm font-semibold flex items-center justify-center mt-0.5">&#10003;</span>
            <div>
              <p class="font-semibold text-charcoal">You're ready to create!</p>
              <p class="text-charcoal-light text-sm mt-1">Start Claude Code and ask it to generate images, videos, audio, or 3D models.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- OpenClaw -->
  <section id="openclaw" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[800px]">
      <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-12">
        <!-- Header -->
        <div class="flex items-center gap-4 mb-10">
          <div class="w-12 h-12 rounded-xl bg-[#FFE5E5] flex items-center justify-center">
            <img src="/icons/openclaw.svg" alt="OpenClaw" class="w-7 h-7" />
          </div>
          <div>
            <h2 class="font-display text-2xl md:text-3xl text-charcoal">OpenClaw</h2>
            <p class="text-sm text-charcoal-light mt-1">Connect via Settings</p>
          </div>
        </div>

        <!-- Steps -->
        <ol class="space-y-6">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">1</span>
            <div>
              <p class="font-semibold text-charcoal">Open Settings</p>
              <p class="text-charcoal-light text-sm mt-1">In OpenClaw, navigate to <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Settings</span> &rarr; <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">MCP Plugins</span>.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">2</span>
            <div>
              <p class="font-semibold text-charcoal">Add a new MCP</p>
              <p class="text-charcoal-light text-sm mt-1">Click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Add MCP Plugin</span> and enter the following URL:</p>
              <div class="mt-2 bg-charcoal rounded-xl px-4 py-3 font-mono text-sm text-white/90 overflow-x-auto">
                https://mcp.creativeclaw.co/mcp
              </div>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-claude-orange text-white text-sm font-semibold flex items-center justify-center mt-0.5">3</span>
            <div>
              <p class="font-semibold text-charcoal">Authenticate</p>
              <p class="text-charcoal-light text-sm mt-1">Click the <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Login</span> button on the CreativeClaw MCP entry and sign in with Gmail.</p>
            </div>
          </li>

          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-green-ink text-sm font-semibold flex items-center justify-center mt-0.5">&#10003;</span>
            <div>
              <p class="font-semibold text-charcoal">You're ready to create!</p>
              <p class="text-charcoal-light text-sm mt-1">Start a new conversation and ask OpenClaw to generate images, videos, audio, or 3D models.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Need Help -->
  <section class="px-4 md:px-6 pb-20">
    <div class="mx-auto max-w-[800px] text-center">
      <p class="text-charcoal-light">
        Need help? Reach out at
        <a href="mailto:hello@creativeclaw.co" class="text-claude-orange hover:underline font-semibold">hello@creativeclaw.co</a>
      </p>
    </div>
  </section>

  <Footer />
</Layout>
