---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="How to Connect — CreativeClaw" description="Get CreativeClaw running in Claude Desktop, Claude Code, or OpenClaw in under a minute. Step-by-step setup instructions.">
  <!-- BreadcrumbList Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://creativeclaw.co" },
      { "@type": "ListItem", "position": 2, "name": "How to Connect", "item": "https://creativeclaw.co/how-to-connect" }
    ]
  })} />

  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-cream/90 backdrop-blur-md border-b border-cream-dark/40">
    <div class="mx-auto max-w-[1200px] px-6 flex items-center justify-between h-16">
      <a href="/">
        <img src="/logo-with-text.png" alt="CreativeClaw" class="h-10" />
      </a>
      <div></div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="px-4 md:px-6 pt-16 pb-12">
    <div class="mx-auto max-w-[1200px] text-center">
      <h1 class="font-display text-4xl md:text-6xl tracking-tight text-charcoal mb-6">
        How to Connect
      </h1>
      <p class="text-lg md:text-xl text-charcoal-light max-w-[600px] mx-auto">
        Get CreativeClaw running in your favorite AI assistant in under a minute.
      </p>
    </div>
  </section>

  <!-- What to Install — explainer -->
  <section class="px-4 md:px-6 pb-16">
    <div class="mx-auto max-w-[900px]">
      <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-10">
        <h2 class="font-display text-2xl md:text-3xl text-charcoal mb-6">What to Install</h2>
        <p class="text-charcoal-light leading-relaxed mb-6">
          CreativeClaw has two components you can install independently:
        </p>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- MCP Connector -->
          <div class="bg-cream rounded-[16px] p-6 border border-cream-dark/30">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-lg bg-claude-orange/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-claude-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>
              </div>
              <h3 class="font-semibold text-charcoal text-lg">MCP Connector</h3>
            </div>
            <p class="text-sm text-charcoal-light leading-relaxed mb-3">
              The core connection. Gives Claude access to all CreativeClaw tools — image generation, video, audio, 3D, brand assets, and more.
            </p>
            <span class="inline-block text-xs font-semibold text-claude-orange bg-claude-orange/10 px-2.5 py-1 rounded-full">Recommended — start here</span>
          </div>
          <!-- Plugin with Skills -->
          <div class="bg-cream rounded-[16px] p-6 border border-cream-dark/30">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-lg bg-purple/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-purple-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
              </div>
              <h3 class="font-semibold text-charcoal text-lg">Plugin + Skills</h3>
            </div>
            <p class="text-sm text-charcoal-light leading-relaxed mb-3">
              Adds Skills that teach Claude how to use CreativeClaw to its full potential — multi-variant generation, brand-aware workflows, and smart model selection.
            </p>
            <span class="inline-block text-xs font-semibold text-charcoal-light bg-cream-dark/40 px-2.5 py-1 rounded-full">Optional — enhances the experience</span>
          </div>
        </div>
        <p class="text-sm text-charcoal-light mt-6">
          You can install the MCP Connector on its own and get full access to all tools. The Plugin adds Skills on top for a smarter experience. Install one or both — it's up to you.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== PART 1: MCP CONNECTOR ===== -->
  <section class="px-4 md:px-6 pb-8">
    <div class="mx-auto max-w-[1200px] text-center">
      <p class="text-sm font-semibold text-claude-orange uppercase tracking-wider mb-3">Part 1</p>
      <h2 class="font-display text-3xl md:text-4xl tracking-tight text-charcoal mb-4">
        Connect the MCP
      </h2>
      <p class="text-base text-charcoal-light max-w-[550px] mx-auto mb-12">
        Add the CreativeClaw connector to get access to all creative tools.
      </p>
    </div>
  </section>

  <!-- MCP: Claude Desktop -->
  <section id="claude-desktop" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[1200px]">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Steps -->
        <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-10">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-[#F4E8DC] flex items-center justify-center">
              <svg height="28" viewBox="0 0 24 24" width="28" xmlns="http://www.w3.org/2000/svg"><path d="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z" fill="#D97757" fill-rule="nonzero"></path></svg>
            </div>
            <div>
              <h2 class="font-display text-2xl md:text-3xl text-charcoal">Claude Desktop</h2>
              <p class="text-sm text-charcoal-light mt-1">Add the MCP Connector</p>
            </div>
          </div>

          <ol class="space-y-5">
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">1</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Open the Customize tab</p>
                <p class="text-charcoal-light text-sm mt-0.5">Click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Customize</span> in your Claude Desktop sidebar.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">2</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Go to Connectors</p>
                <p class="text-charcoal-light text-sm mt-0.5">Click the <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">+</span> next to <strong>Connectors</strong>, then select <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Add Custom Connector</span>.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">3</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Enter the connector details</p>
                <div class="mt-1.5 space-y-1.5">
                  <div class="flex items-center gap-2 text-sm">
                    <span class="text-charcoal-light font-medium w-12">Name</span>
                    <span class="bg-charcoal rounded-lg px-3 py-1.5 font-mono text-xs text-white/90">Creative Claw</span>
                  </div>
                  <div class="flex items-center gap-2 text-sm">
                    <span class="text-charcoal-light font-medium w-12">URL</span>
                    <span class="bg-charcoal rounded-lg px-3 py-1.5 font-mono text-xs text-white/90">https://app.creativeclaw.co/mcp</span>
                  </div>
                </div>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">4</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Add and Authenticate</p>
                <p class="text-charcoal-light text-sm mt-0.5">Click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Add</span>, then click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Authenticate</span> and log in with Gmail.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-green text-green-ink text-xs font-semibold flex items-center justify-center mt-0.5">&#10003;</span>
              <p class="font-semibold text-charcoal text-sm">You're ready to create!</p>
            </li>
          </ol>
        </div>

        <!-- Image -->
        <div>
          <div class="bg-coral rounded-[20px] aspect-square max-w-[445px] max-h-[445px] relative overflow-hidden">
            <img src="/how-it-works/claude-connections-2.webp" alt="Claude Desktop connectors" class="absolute inset-0 w-full h-full object-cover" style="object-position: calc(50% + 50px) center;" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MCP: Claude Code -->
  <section id="claude-code" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[1200px]">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Terminal view (left on desktop) -->
        <div class="md:order-1 order-2">
          <div class="bg-[#1e1e1e] rounded-[20px] p-6 md:p-8 aspect-square max-w-[445px] max-h-[445px] flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-6">
              <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
              <div class="w-3 h-3 rounded-full bg-[#FEBC2E]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28C840]"></div>
              <span class="ml-2 text-xs text-white/30 font-mono">terminal</span>
            </div>
            <div class="space-y-5 font-mono text-sm">
              <div>
                <p class="text-white/40 text-xs mb-1.5"># Add the MCP connector</p>
                <p class="text-green/90 leading-relaxed break-all"><span class="text-white/50">$ </span>claude mcp add creative-claw https://app.creativeclaw.co/mcp --transport streamable-http</p>
              </div>
              <div>
                <p class="text-white/40 text-xs mb-1.5"># Authenticate</p>
                <p class="text-green/90 leading-relaxed break-all"><span class="text-white/50">$ </span>claude mcp auth creative-claw</p>
              </div>
              <p class="text-white/50 text-xs mt-4">&#10003; Ready to create!</p>
            </div>
          </div>
        </div>

        <!-- Steps (right on desktop) -->
        <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-10 md:order-2 order-1">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-[#F4E8DC] flex items-center justify-center">
              <svg height="28" viewBox="0 0 24 24" width="28" xmlns="http://www.w3.org/2000/svg"><path clip-rule="evenodd" d="M20.998 10.949H24v3.102h-3v3.028h-1.487V20H18v-2.921h-1.487V20H15v-2.921H9V20H7.488v-2.921H6V20H4.487v-2.921H3V14.05H0V10.95h3V5h17.998v5.949zM6 10.949h1.488V8.102H6v2.847zm10.51 0H18V8.102h-1.49v2.847z" fill="#D97757" fill-rule="evenodd"></path></svg>
            </div>
            <div>
              <h2 class="font-display text-2xl md:text-3xl text-charcoal">Claude Code</h2>
              <p class="text-sm text-charcoal-light mt-1">Add the MCP Connector</p>
            </div>
          </div>

          <ol class="space-y-5">
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">1</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Add the MCP</p>
                <div class="mt-1.5 bg-charcoal rounded-lg px-3 py-2 font-mono text-xs text-white/90 overflow-x-auto">
                  <span class="text-white/40 select-none">$ </span>claude mcp add creative-claw https://app.creativeclaw.co/mcp --transport streamable-http
                </div>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">2</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Authenticate</p>
                <div class="mt-1.5 bg-charcoal rounded-lg px-3 py-2 font-mono text-xs text-white/90 overflow-x-auto">
                  <span class="text-white/40 select-none">$ </span>claude mcp auth creative-claw
                </div>
                <p class="text-charcoal-light text-sm mt-1.5">This will open your browser to log in with Gmail.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-green text-green-ink text-xs font-semibold flex items-center justify-center mt-0.5">&#10003;</span>
              <p class="font-semibold text-charcoal text-sm">You're ready to create!</p>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- MCP: OpenClaw -->
  <section id="openclaw" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[1200px]">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Steps -->
        <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-10">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-[#FFE5E5] flex items-center justify-center">
              <img src="/icons/openclaw.svg" alt="OpenClaw" class="w-7 h-7" />
            </div>
            <div>
              <h2 class="font-display text-2xl md:text-3xl text-charcoal">OpenClaw</h2>
              <p class="text-sm text-charcoal-light mt-1">Add the MCP Connector</p>
            </div>
          </div>

          <ol class="space-y-5">
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">1</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Open Settings</p>
                <p class="text-charcoal-light text-sm mt-0.5">Navigate to <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Settings</span> &rarr; <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">MCP Plugins</span>.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">2</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Add a new MCP</p>
                <p class="text-charcoal-light text-sm mt-0.5">Click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Add MCP Plugin</span> and enter:</p>
                <div class="mt-1.5 bg-charcoal rounded-lg px-3 py-2 font-mono text-xs text-white/90 overflow-x-auto">
                  https://mcp.creativeclaw.co/mcp
                </div>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-claude-orange text-white text-xs font-semibold flex items-center justify-center mt-0.5">3</span>
              <div>
                <p class="font-semibold text-charcoal text-sm">Authenticate</p>
                <p class="text-charcoal-light text-sm mt-0.5">Click <span class="font-mono text-xs bg-cream-dark/60 px-1.5 py-0.5 rounded">Login</span> on the CreativeClaw MCP entry and sign in with Gmail.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-green text-green-ink text-xs font-semibold flex items-center justify-center mt-0.5">&#10003;</span>
              <p class="font-semibold text-charcoal text-sm">You're ready to create!</p>
            </li>
          </ol>
        </div>

        <!-- OpenClaw icon -->
        <div class="bg-coral/15 rounded-[20px] aspect-square max-w-[445px] max-h-[445px] flex items-center justify-center">
          <div class="flex flex-col items-center gap-6">
            <div class="relative">
              <div class="absolute inset-0 bg-coral/20 rounded-full blur-3xl scale-150"></div>
              <img src="/icons/openclaw.svg" alt="OpenClaw" class="w-32 h-32 md:w-40 md:h-40 relative z-10" />
            </div>
            <span class="text-lg font-display text-charcoal/60">OpenClaw</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PART 2: PLUGIN + SKILLS ===== -->
  <section class="px-4 md:px-6 pb-8">
    <div class="mx-auto max-w-[1200px] text-center">
      <p class="text-sm font-semibold text-purple-ink uppercase tracking-wider mb-3">Part 2 — Optional</p>
      <h2 class="font-display text-3xl md:text-4xl tracking-tight text-charcoal mb-4">
        Install the Plugin + Skills
      </h2>
      <p class="text-base text-charcoal-light max-w-[600px] mx-auto mb-12">
        The Plugin adds Skills that teach Claude how to get the best results from CreativeClaw — multi-variant generation, brand-aware workflows, and smart model selection.
      </p>
    </div>
  </section>

  <!-- Plugin: Claude Desktop -->
  <section id="plugin-claude-desktop" class="px-4 md:px-6 pb-20 scroll-mt-24">
    <div class="mx-auto max-w-[1200px]">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Video -->
        <div class="bg-orange/20 rounded-[20px] p-4 md:p-6 flex items-center justify-center md:order-1 order-2">
          <video
            class="w-full rounded-xl shadow-lg"
            controls
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="/how-to-connect/calude-desktop.mp4" type="video/mp4" />
          </video>
        </div>

        <!-- Steps -->
        <div class="bg-white rounded-[20px] border border-cream-dark/40 p-8 md:p-10 md:order-2 order-1">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-[#F4E8DC] flex items-center justify-center">
