---
const models = [
  { name: 'Flux', description: 'Fast, high-quality image generation', bg: 'bg-pink' },
  { name: 'Midjourney', description: 'Artistic, stylized imagery', bg: 'bg-purple' },
  { name: 'DALL-E', description: 'Versatile text-to-image', bg: 'bg-orange' },
  { name: 'Runway', description: 'Professional video generation', bg: 'bg-blue' },
  { name: 'ElevenLabs', description: 'Natural text-to-speech', bg: 'bg-green' },
  { name: '+ More on Fal.ai', description: 'New models added constantly', bg: 'bg-yellow' },
];
---

<section id="models" class="py-20 md:py-28 px-6">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal text-center">
      Access Every Top AI Model
    </h2>
    <p class="mt-5 text-lg text-charcoal-light text-center max-w-2xl mx-auto">
      One account. One payment method. Every model.
    </p>

    <div class="mt-14 grid grid-cols-2 md:grid-cols-3 gap-5">
      {models.map(model => (
        <div class={`${model.bg} rounded-[20px] p-6 md:p-8 flex flex-col justify-between min-h-[180px] md:min-h-[220px] group hover:scale-[1.02] transition-transform`}>
          <div>
            <!-- Logo placeholder -->
            <div class="w-12 h-12 rounded-[12px] bg-white/30 mb-4 flex items-center justify-center">
              <span class="text-xs font-semibold text-charcoal/50">Logo</span>
            </div>
          </div>
          <div>
            <h3 class="font-semibold text-lg text-charcoal">{model.name}</h3>
            <p class="mt-1 text-sm text-charcoal/60">{model.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="#waitlist" class="inline-block rounded-full border border-cream-dark text-charcoal text-sm font-semibold px-8 py-3 hover:bg-cream-dark/30 transition-colors">
        Explore All Models
      </a>
    </div>
  </div>
</section>
