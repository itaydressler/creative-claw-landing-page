---
const models = [
  { name: 'Flux Pro', description: 'Fast, high-quality image generation', image: '/models/flux.jpg' },
  { name: 'Midjourney', description: 'Artistic, stylized imagery', image: '/models/midjourney.jpg' },
  { name: 'Seedream', description: 'Photorealistic image synthesis', image: '/models/dalle.jpg' },
  { name: 'Kling', description: 'Cinematic video generation', image: '/models/runway.jpg' },
  { name: 'ElevenLabs', description: 'Natural text-to-speech', image: '/models/elevenlabs.jpg' },
  { name: '+ Many More', description: 'Runway, DALL-E, Recraft, Luma & more', image: '/models/falai.jpg' },
];
---

<section id="models" class="py-20 md:py-28 px-6">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal text-center">
      Access Every Top AI Model
    </h2>
    <p class="mt-5 text-lg text-charcoal-light text-center max-w-2xl mx-auto">
      One account. One payment method. Every model.
    </p>

    <div class="mt-14 grid grid-cols-2 md:grid-cols-3 gap-5">
      {models.map(model => (
        <div class="relative rounded-[20px] overflow-hidden min-h-[180px] md:min-h-[220px] group hover:scale-[1.02] transition-transform">
          <img src={model.image} alt={`${model.name} sample output`} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
            <h3 class="font-semibold text-lg text-white">{model.name}</h3>
            <p class="mt-1 text-sm text-white/70">{model.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="#waitlist" class="inline-block rounded-full border border-cream-dark text-charcoal text-sm font-semibold px-8 py-3 hover:bg-cream-dark/30 transition-colors">
        Explore All Models
      </a>
    </div>
  </div>
</section>
