---
---

<!-- Beta signup dialog -->
<div id="beta-dialog-backdrop" class="fixed inset-0 z-50 hidden items-center justify-center bg-charcoal/50 backdrop-blur-sm p-4">
  <div id="beta-dialog" class="bg-surface rounded-[24px] shadow-2xl w-full max-w-md p-8 relative opacity-0 scale-95">
    <!-- Close button -->
    <button id="beta-close" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-cream-dark/30 flex items-center justify-center hover:bg-cream-dark/60 transition-colors">
      <svg class="w-4 h-4 text-charcoal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Logo -->
    <div class="flex items-center gap-3 mb-6">
      <img src="/logo.png" alt="CreativeClaw" class="w-8 h-8" />
      <span class="font-display text-lg text-charcoal">Join the Beta</span>
    </div>

    <!-- Description -->
    <p class="text-sm text-charcoal-light leading-relaxed mb-6">
      Get early access to CreativeClaw. We'll notify you when it's your turn.
    </p>

    <!-- Form -->
    <form id="beta-form" class="space-y-4">
      <!-- Email -->
      <div>
        <label for="beta-email" class="block text-sm font-semibold text-charcoal mb-1.5">Email</label>
        <input
          type="email"
          id="beta-email"
          name="email"
          required
          placeholder="you@company.com"
          class="w-full rounded-xl border border-cream-dark/50 bg-cream px-4 py-3 text-sm text-charcoal placeholder:text-charcoal-light/50 focus:outline-none focus:ring-2 focus:ring-claude-orange/40 focus:border-claude-orange transition-colors"
        />
      </div>

      <!-- Platform -->
      <div>
        <label class="block text-sm font-semibold text-charcoal mb-1.5">I'll use CreativeClaw with</label>
        <div class="grid grid-cols-3 gap-2">
          <label class="platform-option">
            <input type="radio" name="platform" value="claude-desktop" class="sr-only peer" checked />
            <div class="peer-checked:border-claude-orange peer-checked:bg-claude-orange/5 border border-cream-dark/50 rounded-xl p-3 flex flex-col items-center gap-1.5 cursor-pointer hover:border-charcoal-light/50 transition-colors">
              <img src="/icons/claude.svg" alt="Claude" class="w-6 h-6" />
              <span class="text-xs font-semibold text-charcoal">Claude</span>
            </div>
          </label>
          <label class="platform-option">
            <input type="radio" name="platform" value="claude-code" class="sr-only peer" />
            <div class="peer-checked:border-claude-orange peer-checked:bg-claude-orange/5 border border-cream-dark/50 rounded-xl p-3 flex flex-col items-center gap-1.5 cursor-pointer hover:border-charcoal-light/50 transition-colors">
              <img src="/icons/claudecode.svg" alt="Claude Code" class="w-6 h-6" />
              <span class="text-xs font-semibold text-charcoal">Claude Code</span>
            </div>
          </label>
          <label class="platform-option">
            <input type="radio" name="platform" value="openclaw" class="sr-only peer" />
            <div class="peer-checked:border-claude-orange peer-checked:bg-claude-orange/5 border border-cream-dark/50 rounded-xl p-3 flex flex-col items-center gap-1.5 cursor-pointer hover:border-charcoal-light/50 transition-colors">
              <img src="/icons/openclaw.svg" alt="OpenClaw" class="w-6 h-6" />
              <span class="text-xs font-semibold text-charcoal">OpenClaw</span>
            </div>
          </label>
        </div>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full rounded-full bg-claude-orange text-white text-sm font-semibold py-3.5 hover:bg-claude-orange/90 transition-colors mt-2"
      >
        Join the Beta
      </button>
    </form>

    <!-- Success state (hidden initially) -->
    <div id="beta-success" class="hidden text-center py-4">
      <div class="w-14 h-14 rounded-full bg-green/20 flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h3 class="font-display text-xl text-charcoal">You're on the list!</h3>
      <p class="mt-2 text-sm text-charcoal-light">We'll reach out when it's your turn.</p>
    </div>

    <p class="mt-4 text-xs text-charcoal-light/60 text-center">
      No spam. We respect your inbox.
    </p>
  </div>
</div>

<script>
  import gsap from 'gsap';

  function initBetaDialog() {
    const backdrop = document.getElementById('beta-dialog-backdrop');
    const dialog = document.getElementById('beta-dialog');
    const closeBtn = document.getElementById('beta-close');
    const form = document.getElementById('beta-form');
    const success = document.getElementById('beta-success');

    if (!backdrop || !dialog) return;

    function openDialog() {
      backdrop.classList.remove('hidden');
      backdrop.classList.add('flex');
      gsap.fromTo(dialog, {
        opacity: 0, scale: 0.95, y: 20,
      }, {
        opacity: 1, scale: 1, y: 0, duration: 0.35, ease: 'back.out(1.5)',
      });
    }

    function closeDialog() {
      gsap.to(dialog, {
        opacity: 0, scale: 0.95, y: 10, duration: 0.2, ease: 'power2.in',
        onComplete: () => {
          backdrop.classList.add('hidden');
          backdrop.classList.remove('flex');
        },
      });
    }

    // Open on any "join beta" / "join waitlist" link
    document.querySelectorAll('a[href="#waitlist"], a[href="#beta"]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openDialog();
      });
    });

    // Also catch the nav button and final CTA form
    document.querySelectorAll('button[type="submit"]').forEach(btn => {
      const form = btn.closest('form');
      if (form && form.id !== 'beta-form') {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          openDialog();
        });
      }
    });

    // Close
    closeBtn?.addEventListener('click', closeDialog);
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) closeDialog();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !backdrop.classList.contains('hidden')) closeDialog();
    });

    // Form submit
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (document.getElementById('beta-email') as HTMLInputElement)?.value;
      const platform = (form.querySelector('input[name="platform"]:checked') as HTMLInputElement)?.value;

      // TODO: Send to backend
      console.log('Beta signup:', { email, platform });

      // Show success
      gsap.to(form, {
        opacity: 0, y: -10, duration: 0.2,
        onComplete: () => {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          gsap.fromTo(success, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.3 });
        },
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBetaDialog);
  } else {
    initBetaDialog();
  }
</script>
