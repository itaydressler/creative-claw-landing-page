<!-- Claude Iterates to Perfection — animated showcase -->
<div id="iteration-anim" class="absolute inset-0 flex items-center justify-center overflow-hidden">
  <div class="relative w-full h-full flex items-center justify-center">
    <!-- Variant 1 (left, tilted) -->
    <div id="iter-v1" class="absolute w-[26%] rounded-[12px] overflow-hidden shadow-lg opacity-0" style="aspect-ratio:9/16">
      <img src="/how-it-works/iterations/variant-1.png" alt="Variant 1" class="w-full h-full object-cover" width="512" height="512" />
      <div id="iter-x1" class="absolute inset-0 flex items-center justify-center opacity-0">
        <div class="w-10 h-10 rounded-full bg-red-500/90 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </div>
      </div>
    </div>

    <!-- Variant 2 (center, bigger) -->
    <div id="iter-v2" class="absolute w-[32%] rounded-[14px] overflow-hidden shadow-2xl opacity-0 z-10" style="aspect-ratio:9/16">
      <img src="/how-it-works/iterations/variant-2.png" alt="Variant 2" class="w-full h-full object-cover" width="512" height="512" />
    </div>

    <!-- Variant 3 (right, tilted) -->
    <div id="iter-v3" class="absolute w-[26%] rounded-[12px] overflow-hidden shadow-lg opacity-0" style="aspect-ratio:9/16">
      <img src="/how-it-works/iterations/variant-3.png" alt="Variant 3" class="w-full h-full object-cover" width="512" height="512" />
      <div id="iter-x3" class="absolute inset-0 flex items-center justify-center opacity-0">
        <div class="w-10 h-10 rounded-full bg-red-500/90 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </div>
      </div>
    </div>

    <!-- Checkmark for winner -->
    <div id="iter-check" class="absolute z-20 opacity-0 pointer-events-none">
      <div class="w-10 h-10 rounded-full bg-green-500/90 flex items-center justify-center shadow-lg">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </div>
    </div>

    <!-- Final perfected image -->
    <div id="iter-final" class="absolute w-[36%] rounded-[14px] overflow-hidden shadow-2xl opacity-0 z-10" style="aspect-ratio:9/16">
      <img src="/how-it-works/iterations/final.png" alt="Perfected result" class="w-full h-full object-cover" width="400" height="716" />
      <div id="iter-badge" class="absolute top-3 right-3 bg-green-500/90 text-white text-[9px] font-bold px-2.5 py-1 rounded-full shadow-md opacity-0 flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        On Brand
      </div>
    </div>

    <!-- TikTok video (slides in from right) -->
    <div id="iter-video" class="absolute w-[30%] rounded-[14px] overflow-hidden shadow-2xl opacity-0 z-10" style="aspect-ratio:9/16">
      <video muted playsinline loop class="w-full h-full object-cover" id="iter-video-el">
        <source src="/how-it-works/iterations/tiktok-video.mp4" type="video/mp4" />
      </video>
      <!-- TikTok badge -->
      <div id="iter-tiktok-badge" class="absolute top-3 left-3 bg-black/70 backdrop-blur-sm text-white text-[9px] font-bold px-2.5 py-1 rounded-full shadow-md opacity-0 flex items-center gap-1">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.71a8.2 8.2 0 004.76 1.52V6.77a4.83 4.83 0 01-1-.08z"/></svg>
        TikTok
      </div>
    </div>

    <!-- Claude thought bubble at the bottom -->
    <div id="iter-thought" class="absolute bottom-4 left-1/2 -translate-x-1/2 z-30 opacity-0 flex items-center gap-2 bg-white/95 backdrop-blur-sm rounded-2xl md:rounded-full px-3 md:px-4 py-1.5 md:py-2 shadow-lg border border-cream-dark/30 max-w-[90%] md:max-w-none">
      <img src="/icons/claude.svg" alt="Claude" class="w-5 h-5 shrink-0" id="iter-claude-icon" />
      <span id="iter-thought-text" class="text-[10px] md:text-[11px] text-charcoal font-medium md:whitespace-nowrap"></span>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';

  function runIterationAnimation() {
    const v1 = document.getElementById('iter-v1');
    const v2 = document.getElementById('iter-v2');
    const v3 = document.getElementById('iter-v3');
    const x1 = document.getElementById('iter-x1');
    const x3 = document.getElementById('iter-x3');
    const check = document.getElementById('iter-check');
    const final = document.getElementById('iter-final');
    const badge = document.getElementById('iter-badge');
    const thought = document.getElementById('iter-thought');
    const thoughtText = document.getElementById('iter-thought-text');
    const claudeIcon = document.getElementById('iter-claude-icon');

    const video = document.getElementById('iter-video');
    const videoEl = document.getElementById('iter-video-el') as HTMLVideoElement | null;
    const tiktokBadge = document.getElementById('iter-tiktok-badge');

    if (!v1 || !v2 || !v3 || !final || !thought || !thoughtText || !video || !videoEl) return;

    const thoughts = [
      'Generating 3 variants...',
      'Comparing brand consistency...',
      'Colors are off on #1 and #3',
      'Refining #2 to match brand...',
      'On brand ✓',
      'Let\'s repurpose this for TikTok...',
    ];

    function showThought(tl: gsap.core.Timeline, text: string, delay = '+=0.1') {
      tl.to(thought, {
        duration: 0.01,
        onStart: () => { thoughtText.textContent = text; },
      }, delay);
      tl.fromTo(thought,
        { opacity: 0, y: 10 },
        { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' }
      );
      // pulse the claude icon
      tl.to(claudeIcon, {
        scale: 1.2,
        filter: 'drop-shadow(0 0 8px rgba(224,122,58,0.5))',
        duration: 0.2, ease: 'sine.inOut',
      }, '-=0.2');
      tl.to(claudeIcon, {
        scale: 1,
        filter: 'drop-shadow(0 0 0px rgba(224,122,58,0))',
        duration: 0.2, ease: 'sine.inOut',
      });
    }

    function hideThought(tl: gsap.core.Timeline, delay = '+=0.3') {
      tl.to(thought, { opacity: 0, y: 5, duration: 0.2, ease: 'power2.in' }, delay);
    }

    function resetAll() {
      [v1, v2, v3, final].forEach(el => {
        gsap.set(el, { opacity: 0, scale: 0.5, x: 0, y: 30, rotation: 0 });
      });
      [x1, x3].forEach(el => gsap.set(el!, { opacity: 0, scale: 0 }));
      gsap.set(check, { opacity: 0, scale: 0 });
      gsap.set(badge, { opacity: 0, y: -5 });
      gsap.set(thought, { opacity: 0 });
      gsap.set(video, { opacity: 0, scale: 0.5, x: '80%', y: 0 });
      gsap.set(tiktokBadge, { opacity: 0, y: -5 });
      gsap.set(v1, { x: '-75%', rotation: -4 });
      gsap.set(v2, { y: -8 });
      gsap.set(v3, { x: '75%', rotation: 4 });
      thoughtText.textContent = '';
      videoEl.pause();
      videoEl.currentTime = 0;
    }

    function animate() {
      resetAll();

      const tl = gsap.timeline({
        onComplete: () => { setTimeout(animate, 4000); },
      });

      // Phase 1: Fan in 3 variants with thought
      showThought(tl, thoughts[0], '+=0');
      tl.to(v2, { opacity: 1, scale: 1, y: -8, duration: 0.5, ease: 'back.out(1.5)' }, '-=0.2');
      tl.to(v1, { opacity: 0.85, scale: 1, y: 0, duration: 0.5, ease: 'back.out(1.5)' }, '-=0.35');
      tl.to(v3, { opacity: 0.85, scale: 1, y: 0, duration: 0.5, ease: 'back.out(1.5)' }, '-=0.35');
      hideThought(tl, '+=0.3');

      // Phase 2: Claude analyzing
      showThought(tl, thoughts[1]);
      tl.add(() => {}, '+=1');
      hideThought(tl);

      // Phase 3: Reject variant 1 and 3
      showThought(tl, thoughts[2]);
      tl.to(x1, { opacity: 1, scale: 1, duration: 0.25, ease: 'back.out(2)' }, '-=0.1');
      tl.to(x3, { opacity: 1, scale: 1, duration: 0.25, ease: 'back.out(2)' }, '-=0.15');
      // Fade out rejected
      tl.to([v1, v3], { opacity: 0, scale: 0.7, y: 20, duration: 0.5, ease: 'power2.in' }, '+=0.6');
      hideThought(tl, '-=0.2');

      // Phase 4: Winner grows center, check mark
      tl.to(v2, { scale: 1.1, duration: 0.4, ease: 'power2.out' });
      tl.to(check, { opacity: 1, scale: 1, duration: 0.3, ease: 'back.out(2)' });
      tl.to(check, { opacity: 0, scale: 0.5, duration: 0.2 }, '+=0.3');

      // Phase 5: Refine to perfected version
      showThought(tl, thoughts[3]);
      tl.add(() => {}, '+=0.8');

      // Crossfade: v2 out, final in
      tl.to(v2, { opacity: 0, scale: 0.95, duration: 0.35, ease: 'power2.in' });
      tl.fromTo(final,
        { opacity: 0, scale: 0.85, y: 0 },
        { opacity: 1, scale: 1, y: -8, duration: 0.5, ease: 'power2.out' },
        '-=0.25'
      );
      hideThought(tl, '-=0.2');

      // "On Brand" badge + final thought
      showThought(tl, thoughts[4]);
      tl.to(badge, { opacity: 1, y: 0, duration: 0.3, ease: 'back.out(2)' }, '-=0.3');
      hideThought(tl, '+=1');

      // Phase 6: Repurpose for TikTok
      showThought(tl, thoughts[5]);

      // Slide final image to the left, shrink slightly
      tl.to(final, {
        x: '-55%', scale: 0.85, duration: 0.5, ease: 'power2.inOut',
      }, '+=0.5');

      // Video slides in from right
      tl.fromTo(video,
        { opacity: 0, scale: 0.5, x: '80%' },
        { opacity: 1, scale: 0.85, x: '55%', duration: 0.6, ease: 'back.out(1.3)',
          onStart: () => { videoEl.play(); },
        },
        '-=0.3'
      );

      // TikTok badge pops in
      tl.to(tiktokBadge, { opacity: 1, y: 0, duration: 0.3, ease: 'back.out(2)' }, '-=0.2');
      hideThought(tl, '+=0.3');

      // Hold for video playback
      tl.add(() => {}, '+=3');
    }

    animate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runIterationAnimation);
  } else {
    runIterationAnimation();
  }
</script>
