---
---

<section class="py-20 md:py-32 px-6 overflow-hidden">
  <div class="mx-auto max-w-[1200px] text-center">
    <!-- Heading -->
    <h1 class="font-display text-[2.5rem] md:text-[4.5rem] leading-[0.9] tracking-[-0.03em] text-charcoal max-w-4xl mx-auto">
      Generate On-Brand Media,
      <br /><span class="text-claude-orange">Inside Claude.</span>
    </h1>

    <!-- Subheading -->
    <p class="mt-8 text-lg md:text-xl text-charcoal-light max-w-2xl mx-auto leading-relaxed">
      One MCP. Every top AI model. Generate images, video, audio, 3D — all on brand, all inside Claude.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#waitlist"
        class="rounded-full bg-charcoal text-white text-base font-semibold px-8 py-4 hover:bg-charcoal/90 transition-colors"
      >
        Start Creating
      </a>
      <a
        href="#use-cases"
        class="rounded-full border border-cream-dark text-charcoal text-base font-semibold px-8 py-4 hover:bg-cream-dark/30 transition-colors"
      >
        See What You Can Create
      </a>
    </div>

    <!-- Hero media area -->
    <div class="mt-16 relative mx-auto max-w-4xl" id="hero-media">
      <!-- Floating platform icons — animated in with content -->
      <div id="icon-instagram" class="absolute -top-3 left-[13%] z-30 opacity-0 hidden md:block">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 via-pink-500 to-orange-400 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </div>
      </div>
      <div id="icon-youtube" class="absolute -top-6 right-[12%] z-30 opacity-0 hidden md:block">
        <div class="w-10 h-10 rounded-xl bg-red-600 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </div>
      </div>
      <div id="icon-facebook" class="absolute -bottom-8 right-[8%] z-30 opacity-0 hidden md:block">
        <div class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </div>
      </div>

      <!-- Floating content: Instagram Reel (left, tall like a phone) -->
      <div id="float-reel" class="absolute -top-8 -left-4 md:left-0 w-28 md:w-36 rotate-[-4deg] z-20 rounded-[20px] overflow-hidden shadow-2xl opacity-0 scale-50">
        <video autoplay loop muted playsinline class="w-full h-auto">
          <source src="/how-it-works/iterations/tiktok-video.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- Floating content: YouTube video (top-right) — Starbucks video -->
      <div id="float-youtube" class="absolute -top-10 -right-4 md:-right-20 w-44 md:w-52 rotate-[4deg] z-20 rounded-[12px] overflow-hidden shadow-2xl opacity-0 scale-50">
        <img src="/on-brand/youtube-thumb.png" alt="Starbucks YouTube thumbnail" class="w-full h-auto" />
      </div>

      <!-- Floating content: Facebook post (bottom-right) — Starbucks post -->
      <div id="float-facebook" class="absolute -bottom-12 -right-2 md:-right-6 w-32 md:w-40 rotate-[3deg] z-20 rounded-[12px] overflow-hidden shadow-2xl opacity-0 scale-50">
        <img src="/on-brand/starbucks-post.png" alt="Starbucks social post" class="w-full h-auto scale-110" />
      </div>

      <!-- Central Claude input card -->
      <div class="relative z-10 bg-surface rounded-[24px] shadow-2xl max-w-xl mx-auto border border-cream-dark/40">
        <!-- Input area -->
        <div class="p-5 md:p-6 min-h-[80px] text-left">
          <span id="hero-typing" class="text-base md:text-lg text-charcoal leading-relaxed"></span><span id="hero-cursor" class="inline-block w-[2px] h-5 bg-charcoal/60 align-middle ml-0.5 animate-pulse"></span>
        </div>

        <!-- Bottom bar -->
        <div class="px-5 md:px-6 pb-4 md:pb-5 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2 border border-cream-dark/50 rounded-full px-3 py-1.5">
              <svg class="w-4 h-4 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
              </svg>
              <span class="text-sm text-charcoal">Brand assets</span>
            </div>
            <span class="text-xl text-charcoal-light/40 leading-none">+</span>
          </div>

          <!-- Send button — starts disabled -->
          <button id="hero-send-btn" class="bg-cream-dark/50 text-charcoal-light/50 rounded-xl px-5 py-2.5 text-sm font-semibold flex items-center gap-2 transition-all duration-300 cursor-default">
            <span>Let's go</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>
        </div>

        <!-- Claude thinking logo — centered over the card -->
        <div id="claude-thinking" class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 z-20">
          <img src="/icons/claude.svg" alt="" class="w-12 h-12" />
        </div>
      </div>
    </div>

    <!-- Works with -->
    <div class="mt-16 flex flex-col items-center gap-5">
      <p class="text-sm text-charcoal-light font-semibold tracking-wide uppercase">
        Works with
      </p>
      <div class="flex items-center gap-8 md:gap-10">
        <div class="flex items-center gap-2.5 opacity-70 hover:opacity-100 transition-opacity">
          <img src="/icons/claude.svg" alt="Claude" class="w-7 h-7" />
          <span class="text-sm font-semibold text-charcoal">Claude</span>
        </div>
        <div class="flex items-center gap-2.5 opacity-70 hover:opacity-100 transition-opacity">
          <img src="/icons/claudecode.svg" alt="Claude Code" class="w-7 h-7" />
          <span class="text-sm font-semibold text-charcoal">Claude Code</span>
        </div>
        <div class="flex items-center gap-2.5 opacity-70 hover:opacity-100 transition-opacity">
          <img src="/icons/openclaw.svg" alt="OpenClaw" class="w-7 h-7" />
          <span class="text-sm font-semibold text-charcoal">OpenClaw</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const PROMPT = "Create an Instagram Reel, a YouTube video, and a Facebook post for our spring beauty launch. Use our brand colors and keep it on-brand.";

  // Make "Let's go" button open the beta dialog
  const heroSendBtn = document.getElementById('hero-send-btn');
  heroSendBtn?.addEventListener('click', () => {
    (window as any).posthog?.capture('cta_click', { source: 'hero_lets_go' });
    const dialog = document.getElementById('beta-dialog') as HTMLDialogElement | null;
    dialog?.showModal();
  });

  function runHeroAnimation() {
    const typingEl = document.getElementById('hero-typing');
    const cursorEl = document.getElementById('hero-cursor');
    const sendBtn = document.getElementById('hero-send-btn');
    const claudeThinking = document.getElementById('claude-thinking');

    if (!typingEl || !sendBtn || !claudeThinking) return;

    const tl = gsap.timeline({ delay: 0.8 });

    // Phase 1: Typing animation
    let charIndex = 0;
    tl.to({}, {
      duration: PROMPT.length * 0.028,
      onUpdate: function() {
        const progress = this.progress();
        const newIndex = Math.floor(progress * PROMPT.length);
        if (newIndex > charIndex) {
          charIndex = newIndex;
          typingEl.textContent = PROMPT.slice(0, charIndex);
        }
      },
      onComplete: () => {
        typingEl.textContent = PROMPT;
      },
      ease: 'none',
    });

    // Phase 2: Button activates
    tl.to(sendBtn, {
      duration: 0.3,
      onStart: () => {
        sendBtn.classList.remove('bg-cream-dark/50', 'text-charcoal-light/50', 'cursor-default');
        sendBtn.classList.add('bg-claude-orange', 'text-white', 'cursor-pointer');
      },
      ease: 'power2.out',
    }, '+=0.3');

    // Phase 3: Button press → disable
    tl.to(sendBtn, { scale: 0.93, duration: 0.12, ease: 'power2.in' }, '+=0.4');
    tl.to(sendBtn, {
      scale: 1,
      duration: 0.15,
      ease: 'power2.out',
      onComplete: () => {
        if (cursorEl) cursorEl.style.display = 'none';
        sendBtn.classList.remove('bg-claude-orange', 'text-white', 'cursor-pointer');
        sendBtn.classList.add('bg-cream-dark/50', 'text-charcoal-light/50', 'cursor-default');
      },
    });

    // Phase 4: Claude thinking breathe pulse
    tl.to(claudeThinking, { opacity: 1, duration: 0.4, ease: 'power2.out' }, '+=0.1');
    for (let i = 0; i < 3; i++) {
      tl.to(claudeThinking.querySelector('img'), {
        scale: 1.3,
        filter: 'drop-shadow(0 0 20px rgba(224,122,58,0.6)) drop-shadow(0 0 40px rgba(224,122,58,0.3))',
        duration: 0.5,
        ease: 'sine.inOut',
      });
      tl.to(claudeThinking.querySelector('img'), {
        scale: 0.9,
        filter: 'drop-shadow(0 0 8px rgba(224,122,58,0.2)) drop-shadow(0 0 0px rgba(224,122,58,0))',
        duration: 0.5,
        ease: 'sine.inOut',
      });
    }

    // Phase 5: Fade out thinking, pop in content + platform icons
    tl.to(claudeThinking, { opacity: 0, scale: 1.5, duration: 0.3, ease: 'power2.in' });

    const floatTargets = [
      { id: '#float-reel', icon: '#icon-instagram', x: -40, y: -20 },
      { id: '#float-youtube', icon: '#icon-youtube', x: 40, y: -20 },
      { id: '#float-facebook', icon: '#icon-facebook', x: 30, y: 30 },
    ];

    floatTargets.forEach((target, i) => {
      // Pop in the content
      tl.fromTo(target.id, {
        opacity: 0, scale: 0.3, x: target.x, y: target.y,
      }, {
        opacity: 1, scale: 1, x: 0, y: 0, duration: 0.6, ease: 'back.out(1.7)',
      }, i === 0 ? '+=0' : `-=0.4`);

      // Pop in the platform icon badge right after
      tl.fromTo(target.icon, {
        opacity: 0, scale: 0, y: 10,
      }, {
        opacity: 1, scale: 1, y: 0, duration: 0.35, ease: 'back.out(2)',
      }, '-=0.3');
    });

    // Phase 6: Button back to orange
    tl.to(sendBtn, {
      duration: 0.01,
      onComplete: () => {
        sendBtn.classList.remove('bg-cream-dark/50', 'text-charcoal-light/50', 'cursor-default');
        sendBtn.classList.add('bg-claude-orange', 'text-white', 'cursor-pointer');
      },
    }, '-=0.3');

    // Phase 7: Gentle floating bob on content + icons
    tl.add(() => {
      floatTargets.forEach((target, i) => {
        gsap.to(target.id, {
          y: '+=8', duration: 2.2 + i * 0.4, repeat: -1, yoyo: true, ease: 'sine.inOut',
        });
        gsap.to(target.icon, {
          y: '+=6', duration: 2.5 + i * 0.3, repeat: -1, yoyo: true, ease: 'sine.inOut',
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runHeroAnimation);
  } else {
    runHeroAnimation();
  }
</script>
