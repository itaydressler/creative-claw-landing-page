---
const platforms = [
  { name: 'Instagram', icon: 'IG' },
  { name: 'TikTok', icon: 'TT' },
  { name: 'YouTube', icon: 'YT' },
  { name: 'Facebook', icon: 'FB' },
  { name: 'LinkedIn', icon: 'LI' },
  { name: 'X', icon: 'X' },
];
---

<section class="py-20 md:py-32 px-6 overflow-hidden">
  <div class="mx-auto max-w-[1200px] text-center">
    <!-- Heading -->
    <h1 class="font-display text-[2.5rem] md:text-[4.5rem] leading-[0.9] tracking-[-0.03em] text-charcoal max-w-4xl mx-auto">
      Create On-Brand Content,
      <br /><span class="text-claude-orange">Inside Claude.</span>
    </h1>

    <!-- Subheading -->
    <p class="mt-8 text-lg md:text-xl text-charcoal-light max-w-2xl mx-auto leading-relaxed">
      One MCP. Every top AI model. Generate images, video, audio, 3D — all on brand, all inside Claude.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#waitlist"
        class="rounded-full bg-charcoal text-white text-base font-semibold px-8 py-4 hover:bg-charcoal/90 transition-colors"
      >
        Join the Waitlist
      </a>
      <a
        href="#use-cases"
        class="rounded-full border border-cream-dark text-charcoal text-base font-semibold px-8 py-4 hover:bg-cream-dark/30 transition-colors"
      >
        See What You Can Create
      </a>
    </div>

    <!-- Hero media area -->
    <div class="mt-16 relative mx-auto max-w-4xl">
      <!-- Decorative Claude-style lines -->
      <svg class="absolute -top-8 -left-12 w-24 h-24 text-claude-orange/20 hidden md:block" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20,80 Q50,10 80,50" stroke-linecap="round" />
        <path d="M10,60 Q40,20 70,40" stroke-linecap="round" />
        <circle cx="15" cy="75" r="4" fill="currentColor" />
      </svg>
      <svg class="absolute -top-4 -right-16 w-20 h-20 text-purple/30 hidden md:block" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M30,70 Q60,10 90,40" stroke-linecap="round" />
        <circle cx="85" cy="35" r="5" fill="currentColor" />
        <circle cx="35" cy="65" r="3" fill="currentColor" />
      </svg>
      <svg class="absolute -bottom-8 -left-8 w-16 h-16 text-pink/30 hidden md:block" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="50" cy="50" r="20" />
        <circle cx="50" cy="50" r="8" fill="currentColor" />
      </svg>
      <svg class="absolute -bottom-12 right-8 w-20 h-20 text-green/40 hidden md:block" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M20,50 L40,30 L60,50 L80,30" stroke-linecap="round" stroke-linejoin="round" />
        <circle cx="25" cy="48" r="4" fill="currentColor" />
      </svg>

      <!-- Floating image: Social Post (top-left) -->
      <div class="absolute -top-6 -left-8 md:-left-16 w-36 md:w-48 rotate-[-6deg] z-20 rounded-[16px] overflow-hidden shadow-2xl hover:rotate-[-2deg] hover:scale-105 transition-transform duration-500">
        <img src="/hero/social-post.jpg" alt="AI-generated social media post" class="w-full h-auto" />
      </div>

      <!-- Floating image: YouTube Thumbnail (top-right) -->
      <div class="absolute -top-8 -right-4 md:-right-12 w-40 md:w-52 rotate-[5deg] z-20 rounded-[16px] overflow-hidden shadow-2xl hover:rotate-[2deg] hover:scale-105 transition-transform duration-500">
        <img src="/hero/thumbnail.jpg" alt="AI-generated YouTube thumbnail" class="w-full h-auto" />
      </div>

      <!-- Floating image: Product (bottom-left) -->
      <div class="absolute -bottom-8 -left-4 md:left-8 w-32 md:w-40 z-20 drop-shadow-2xl hover:scale-110 transition-transform duration-500">
        <img src="/hero/product.png" alt="AI-generated product shot" class="w-full h-auto" />
      </div>

      <!-- Floating image: Meme (bottom-right) -->
      <div class="absolute -bottom-10 -right-2 md:right-4 w-28 md:w-36 rotate-[6deg] z-20 drop-shadow-2xl hover:rotate-[2deg] hover:scale-110 transition-transform duration-500">
        <img src="/hero/meme.png" alt="AI-generated meme sticker" class="w-full h-auto" />
      </div>

      <!-- Central Claude conversation card -->
      <div class="relative z-10 bg-surface rounded-[24px] shadow-2xl p-6 md:p-8 max-w-md mx-auto border border-cream-dark/30">
        <!-- Claude header -->
        <div class="flex items-center gap-3 mb-4 pb-4 border-b border-cream-dark/30">
          <img src="/logo.png" alt="CreativeClaw" class="w-7 h-7" />
          <span class="text-sm font-semibold text-charcoal">Claude + CreativeClaw</span>
          <div class="ml-auto flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-green/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-coral/60"></div>
          </div>
        </div>

        <!-- User message -->
        <div class="bg-cream rounded-[16px] p-4 mb-4">
          <p class="text-sm text-charcoal leading-relaxed">
            Create 3 on-brand Instagram stories for our spring product launch, a YouTube thumbnail, and a fun meme for our social channels.
          </p>
        </div>

        <!-- Claude response -->
        <div class="flex items-start gap-3">
          <div class="w-6 h-6 rounded-full bg-claude-orange/20 flex items-center justify-center flex-shrink-0 mt-0.5">
            <div class="w-3 h-3 rounded-full bg-claude-orange"></div>
          </div>
          <div>
            <p class="text-sm text-charcoal-light leading-relaxed">
              I'll generate those using Flux Pro for the posts, Runway for video assets, and a fun illustrated style for the meme. All matching your brand palette...
            </p>
            <!-- Generating indicator -->
            <div class="mt-3 flex items-center gap-2">
              <div class="flex gap-1">
                <div class="w-1.5 h-1.5 rounded-full bg-claude-orange animate-pulse"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-claude-orange animate-pulse" style="animation-delay: 0.2s"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-claude-orange animate-pulse" style="animation-delay: 0.4s"></div>
              </div>
              <span class="text-xs text-charcoal-light/60">Generating 5 assets...</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Works with badge -->
    <div class="mt-16 flex flex-col items-center gap-4">
      <p class="text-sm text-charcoal-light font-semibold tracking-wide uppercase">
        Works with Claude Desktop, Claude Code & OpenClaw
      </p>
      <!-- Platform icons -->
      <div class="flex items-center gap-6 mt-2">
        {platforms.map(p => (
          <div class="flex flex-col items-center gap-1 opacity-50 hover:opacity-100 transition-opacity">
            <div class="w-8 h-8 rounded-lg bg-cream-dark flex items-center justify-center text-xs font-semibold text-charcoal-light">
              {p.icon}
            </div>
            <span class="text-[10px] text-charcoal-light">{p.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
