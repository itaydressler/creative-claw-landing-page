---
---

<section id="use-cases" class="py-20 md:py-28 px-6">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal text-center">
      What Will You Create?
    </h2>
    <p class="mt-5 text-lg text-charcoal-light text-center max-w-2xl mx-auto">
      From social content to product videos — all on brand, all in one conversation.
    </p>

    <!-- Bento Grid -->
    <div class="mt-14 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-5">

      <!-- Row 1: Short-Form Video (large, 7 cols) + Social Media Posts (5 cols) -->

      <!-- Short-Form Video — tall card -->
      <div class="md:col-span-7 bg-purple rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/short-form-video.png" alt="Short-form video mockups showing TikTok and Reels" class="w-[85%] max-w-[400px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-2xl md:text-3xl text-charcoal">Short-Form Video</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed max-w-xs">
            Create engaging Reels, TikToks & Shorts with voiceover, music & narration
          </p>
        </div>
      </div>

      <!-- Social Media Posts — tall card with pink bg -->
      <div class="md:col-span-5 bg-pink rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/social-posts.png" alt="Social media post designs overlapping" class="w-[90%] max-w-[380px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-2xl md:text-3xl text-charcoal">Social Media Posts</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed max-w-xs">
            Design on-brand posts for every platform in seconds
          </p>
        </div>
      </div>

      <!-- Row 2: Product Videos (5 cols) + Memes (3 cols) + YouTube Thumbnails (4 cols) -->

      <!-- Product Videos with Remotion -->
      <div class="md:col-span-5 bg-green rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[320px] md:min-h-[380px] flex flex-col justify-between">
        <!-- Image slot -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full h-full min-h-[160px] rounded-[16px] bg-white/15 flex items-center justify-center">
            <span class="text-charcoal/30 text-sm font-semibold">Asset: Remotion video frame</span>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Product Videos</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed">
            Programmatic videos with Remotion — fully customizable, on-brand
          </p>
        </div>
      </div>

      <!-- Memes & Viral Content -->
      <div class="md:col-span-3 bg-yellow rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[320px] md:min-h-[380px] flex flex-col justify-between">
        <!-- Image slot -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full h-full min-h-[140px] rounded-[16px] bg-white/15 flex items-center justify-center">
            <span class="text-charcoal/30 text-xs font-semibold">Asset: Meme</span>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Memes</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Trending formats & viral content in seconds
          </p>
        </div>
      </div>

      <!-- YouTube Thumbnails -->
      <div class="md:col-span-4 bg-blue rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[320px] md:min-h-[380px] flex flex-col justify-between">
        <!-- Image slot -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full h-full min-h-[140px] rounded-[16px] bg-white/15 flex items-center justify-center">
            <span class="text-charcoal/30 text-sm font-semibold">Asset: Thumbnail</span>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Thumbnails</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Eye-catching YouTube thumbnails that drive clicks
          </p>
        </div>
      </div>

      <!-- Row 3: Ad Creatives (4 cols) + Email Campaigns (4 cols) + Logo Animations (4 cols) -->

      <!-- Ad Creatives -->
      <div class="md:col-span-4 bg-coral rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[300px] md:min-h-[340px] flex flex-col justify-between">
        <!-- Image slot -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full h-full min-h-[120px] rounded-[16px] bg-white/15 flex items-center justify-center">
            <span class="text-white/40 text-sm font-semibold">Asset: Ad creative</span>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-white">Ad Creatives</h3>
          <p class="mt-1 text-sm text-white/70 leading-relaxed">
            High-converting ads for Facebook, Instagram & YouTube
          </p>
        </div>
      </div>

      <!-- Email Campaign Assets -->
      <div class="md:col-span-4 bg-orange rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[300px] md:min-h-[340px] flex flex-col justify-between">
        <!-- Image slot -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full h-full min-h-[120px] rounded-[16px] bg-white/15 flex items-center justify-center">
            <span class="text-white/40 text-sm font-semibold">Asset: Email header</span>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Email Campaigns</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Headers, banners & visuals for personalized campaigns
          </p>
        </div>
      </div>

      <!-- Logo Animations -->
      <div class="md:col-span-4 bg-charcoal rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[300px] md:min-h-[340px] flex flex-col justify-between">
        <!-- Image slot -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full h-full min-h-[120px] rounded-[16px] bg-white/10 flex items-center justify-center">
            <span class="text-white/30 text-sm font-semibold">Asset: Animated logo</span>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-white">Logo Animations</h3>
          <p class="mt-1 text-sm text-white/50 leading-relaxed">
            Animate your logo with burst effects & motion
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
