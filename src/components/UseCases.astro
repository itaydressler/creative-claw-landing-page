---
---

<section id="use-cases" class="py-20 md:py-28 px-6">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal text-center">
      What Will You Create?
    </h2>
    <p class="mt-5 text-lg text-charcoal-light text-center max-w-2xl mx-auto">
      From social content to product videos — all on brand, all in one conversation.
    </p>

    <!-- Bento Grid -->
    <div class="mt-14 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-5">

      <!-- Row 1: Short-Form Video (large, 7 cols) + Social Media Posts (5 cols) -->

      <!-- Short-Form Video — tall card -->
      <div class="md:col-span-7 bg-purple rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Video -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-[180px] md:w-[220px] rotate-[-3deg] rounded-[20px] overflow-hidden shadow-2xl">
            <video autoplay loop muted playsinline class="w-full h-auto">
              <source src="/lumiglow-morning-routine-real-talk.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-2xl md:text-3xl text-charcoal">Short-Form Video</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed max-w-xs">
            Create engaging Reels, TikToks & Shorts with voiceover, music & narration
          </p>
        </div>
      </div>

      <!-- Social Media Posts — tall card with pink bg -->
      <div class="md:col-span-5 bg-pink rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Animated clay social icons -->
        <div id="social-posts-anim" class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/social-4.png" alt="Instagram clay post" class="social-card absolute w-[50%] max-w-[190px] drop-shadow-xl opacity-0 z-20" style="left: 22%; top: 8%;" />
          <img src="/use-cases/social-1.png" alt="X clay icon" class="social-card absolute w-[30%] max-w-[120px] drop-shadow-xl opacity-0" style="left: 3%; top: 45%;" />
          <img src="/use-cases/social-2.png" alt="Facebook clay icon" class="social-card absolute w-[26%] max-w-[100px] drop-shadow-xl opacity-0" style="left: 5%; top: 5%;" />
          <img src="/use-cases/social-3.png" alt="LinkedIn clay icon" class="social-card absolute w-[32%] max-w-[130px] drop-shadow-xl opacity-0" style="right: 3%; top: 40%;" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-2xl md:text-3xl text-charcoal">Social Media Posts</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed max-w-xs">
            Design on-brand posts for every platform in seconds
          </p>
        </div>
      </div>

      <!-- Row 2: Product Videos (5 cols) + Memes (3 cols) + YouTube Thumbnails (4 cols) -->

      <!-- Product Videos with Remotion -->
      <div class="md:col-span-5 bg-green rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[320px] md:min-h-[380px] flex flex-col justify-between">
        <!-- Video -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full rounded-[16px] overflow-hidden shadow-lg">
            <video
              autoplay
              loop
              muted
              playsinline
              poster="/use-cases/product-video-poster.png"
              class="w-full h-auto"
            >
              <source src="/use-cases/product-video.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Product Videos</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed">
            Programmatic videos with Remotion — fully customizable, on-brand
          </p>
        </div>
      </div>

      <!-- Memes & Viral Content -->
      <div class="md:col-span-3 bg-yellow rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[320px] md:min-h-[380px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/memes.png" alt="Stacked meme cards" class="w-[95%] max-w-[260px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Memes</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Trending formats & viral content in seconds
          </p>
        </div>
      </div>

      <!-- YouTube Thumbnails -->
      <div class="md:col-span-4 bg-blue rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[320px] md:min-h-[380px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/thumbnails.png" alt="YouTube thumbnail designs" class="w-[95%] max-w-[340px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Thumbnails</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Eye-catching YouTube thumbnails that drive clicks
          </p>
        </div>
      </div>

      <!-- Row 3: Ad Creatives (4 cols) + Email Campaigns (4 cols) + Logo Animations (4 cols) -->

      <!-- Ad Creatives -->
      <div class="md:col-span-4 bg-pink rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[300px] md:min-h-[340px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/ad-creatives.png" alt="Ad creative banner designs" class="w-[95%] max-w-[300px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Ad Creatives</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            High-converting ads for Facebook, Instagram & YouTube
          </p>
        </div>
      </div>

      <!-- Email Campaign Assets -->
      <div class="md:col-span-4 bg-orange rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[300px] md:min-h-[340px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/email-campaigns.png" alt="Email newsletter designs" class="w-[90%] max-w-[300px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Email Campaigns</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Headers, banners & visuals for personalized campaigns
          </p>
        </div>
      </div>

      <!-- Logo Animations -->
      <div class="md:col-span-4 bg-purple rounded-[24px] p-6 md:p-7 relative overflow-hidden min-h-[300px] md:min-h-[340px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/logo-animations.png" alt="3D logo animation burst" class="w-[90%] max-w-[280px] h-auto drop-shadow-xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-xl md:text-2xl text-charcoal">Logo Animations</h3>
          <p class="mt-1 text-sm text-charcoal/60 leading-relaxed">
            Animate your logo with burst effects & motion
          </p>
        </div>
      </div>

      <!-- Row 4: Remotion Videos (7 cols) + Landing Pages (5 cols) -->

      <!-- Remotion Videos -->
      <div class="md:col-span-7 bg-charcoal rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Floating React icon -->
        <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
          <div class="w-12 h-12 rounded-xl bg-[#61DAFB]/20 backdrop-blur-sm flex items-center justify-center shadow-lg border border-[#61DAFB]/30">
            <svg class="w-7 h-7 text-[#61DAFB]" viewBox="-11.5 -10.232 23 20.463" fill="currentColor">
              <circle r="2.05"></circle>
              <g stroke="currentColor" fill="none" stroke-width="1">
                <ellipse rx="11" ry="4.2"></ellipse>
                <ellipse rx="11" ry="4.2" transform="rotate(60)"></ellipse>
                <ellipse rx="11" ry="4.2" transform="rotate(120)"></ellipse>
              </g>
            </svg>
          </div>
        </div>
        <!-- Video -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full max-w-[520px] rounded-[12px] overflow-hidden">
            <video autoplay loop muted playsinline class="w-full h-auto">
              <source src="/use-cases/remotion-compose.webm" type="video/webm" />
            </video>
          </div>
        </div>
        <!-- Text -->
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 mt-1">
            <img src="/icons/remotion.svg" alt="Remotion" class="w-7 h-7" style="filter: brightness(0) invert(1);" />
          </div>
          <div>
            <h3 class="font-display text-2xl md:text-3xl text-white">Remotion Videos</h3>
            <p class="mt-2 text-sm text-white/60 leading-relaxed max-w-md">
              Build full video productions with Remotion — insert AI-generated images, video clips & text-to-speech narration, all assembled programmatically
            </p>
          </div>
        </div>
      </div>

      <!-- Landing Pages -->
      <div class="md:col-span-5 bg-blue rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Image -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/generate-webpages.webp" alt="AI-generated landing page" class="w-[95%] max-w-[400px] h-auto rounded-[12px] shadow-2xl object-contain" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-2xl md:text-3xl text-charcoal">Landing Pages</h3>
          <p class="mt-2 text-sm text-charcoal/60 leading-relaxed max-w-xs">
            Generate complete landing pages with AI imagery, copy & design — ship faster than ever
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function animateSocialPosts() {
    const cards = document.querySelectorAll('.social-card');
    if (!cards.length) return;

    // Stagger pop-in
    gsap.fromTo(cards,
      { opacity: 0, y: 30, scale: 0.8 },
      { opacity: 1, y: 0, scale: 1, duration: 0.6, stagger: 0.2, ease: 'back.out(1.5)' }
    );

    // Gentle floating bob on each card
    cards.forEach((card, i) => {
      gsap.to(card, {
        y: `+=${6 + i * 3}`,
        rotation: `+=${1.5 - i * 1.5}`,
        duration: 2.5 + i * 0.5,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: i * 0.4,
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animateSocialPosts);
  } else {
    animateSocialPosts();
  }
</script>
