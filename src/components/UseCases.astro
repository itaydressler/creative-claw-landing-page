---
---

<section id="use-cases" class="py-20 md:py-28 px-6">
  <div class="mx-auto max-w-[1000px]">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal text-center">
      What Will You Create?
    </h2>
    <p class="mt-5 text-lg text-charcoal-light text-center max-w-2xl mx-auto">
      From social content to product videos — all on brand, all in one conversation.
    </p>

    <!-- Bento Grid — using nested flex for proper square cards -->
    <div class="mt-14 flex flex-col gap-4 md:gap-5">

      <!-- Block 1: Short-Form Video (tall left) + right column (Social Media + 2 squares) -->
      <div class="flex flex-col md:flex-row gap-4 md:gap-5">
        <!-- Short-Form Video — tall left card -->
        <div class="md:w-5/12 bg-purple rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[340px] flex flex-col">
          <div>
            <h3 class="font-display text-2xl md:text-3xl text-purple-ink">Short-Form Video</h3>
          </div>
          <div class="flex-1 relative flex items-center justify-center my-4">
            <div class="w-[150px] md:w-[190px] rotate-[-5deg] rounded-[20px] overflow-hidden shadow-2xl relative z-10 -mr-8">
              <video loop muted playsinline preload="none" class="w-full h-auto lazy-video">
                <source src="/lumiglow-morning-routine-real-talk.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="w-[150px] md:w-[190px] rotate-[5deg] rounded-[20px] overflow-hidden shadow-2xl relative z-20 -ml-8">
              <video loop muted playsinline preload="none" class="w-full h-auto lazy-video">
                <source src="/use-cases/tiktoker.mp4" type="video/mp4" />
              </video>
            </div>
          </div>
          <div>
            <p class="text-base text-purple-ink leading-snug max-w-xs">
              Create engaging Reels, TikToks & Shorts with voiceover, music & narration
            </p>
          </div>
        </div>

        <!-- Right column -->
        <div class="md:w-7/12 flex flex-col gap-4 md:gap-5">
          <!-- Social Media Posts -->
          <div class="bg-pink rounded-[24px] p-7 md:p-8 relative overflow-visible min-h-[220px] flex flex-col justify-end">
            <div class="flex-1 relative mb-4">
              <img src="/use-cases/instagram-post.webp" alt="Instagram post mockup" class="absolute drop-shadow-2xl rotate-[-6deg] z-10 rounded-lg" style="width: 30%; right: 18%; top: -22px;" width="1317" height="1687" />
              <img src="/use-cases/linkedin-post.webp" alt="LinkedIn post mockup" class="absolute drop-shadow-2xl rotate-[5deg] z-20 rounded-lg" style="width: 30%; right: 2%; top: -20px;" width="1317" height="1687" />
            </div>
            <div class="relative z-10">
              <h3 class="font-display text-2xl md:text-3xl text-pink-ink">Social Media Posts</h3>
              <p class="mt-2 text-base text-pink-ink leading-snug max-w-[200px]">
                Design on-brand posts for every platform in seconds
              </p>
            </div>
          </div>

          <!-- Two square cards side by side -->
          <div class="flex flex-col sm:flex-row gap-4 md:gap-5">
            <!-- Product Videos — square -->
            <div class="sm:w-[57%] bg-green rounded-[24px] p-6 md:p-7 relative overflow-hidden flex flex-col justify-between aspect-square">
              <div class="flex-1 flex items-center justify-center mb-3">
                <div class="w-full rounded-[12px] overflow-hidden shadow-lg">
                  <video loop muted playsinline preload="none" class="w-full h-auto lazy-video">
                    <source src="/use-cases/product-video.mp4" type="video/mp4" />
                  </video>
                </div>
              </div>
              <div>
                <h3 class="font-display text-xl md:text-2xl text-green-ink">Product Videos</h3>
                <p class="mt-1 text-base text-green-ink leading-snug">
                  AI images & video in Remotion projects
                </p>
              </div>
            </div>

            <!-- Logo Design — square -->
            <div class="sm:w-[43%] bg-yellow rounded-[24px] p-6 md:p-7 relative overflow-hidden flex flex-col aspect-square">
              <div class="relative z-10 mb-3">
                <h3 class="font-display text-xl md:text-2xl text-yellow-ink">Logo Design</h3>
                <p class="mt-1 text-base text-yellow-ink leading-snug">
                  Generate & iterate on logos with AI
                </p>
              </div>
              <div class="flex-1 relative">
                <img src="/use-cases/logo-1.webp" alt="AI-generated logo" class="absolute w-[120%] drop-shadow-xl" style="top: -15%; left: -30%; rotate: -8deg; z-index: 3;" width="1408" height="768" />
                <img src="/use-cases/logo-2.webp" alt="AI-generated logo" class="absolute w-[120%] drop-shadow-xl" style="top: 0%; right: -35%; rotate: 6deg; z-index: 2;" width="1408" height="768" />
                <img src="/use-cases/logo-3.webp" alt="AI-generated logo" class="absolute w-[110%] drop-shadow-xl" style="bottom: -30%; left: 10%; rotate: -3deg; z-index: 1;" width="1408" height="768" />
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Block 2: Mirrored — left column (Product Marketing + 2 squares) + Ad Creatives (tall right) -->
      <div class="flex flex-col md:flex-row gap-4 md:gap-5">
        <!-- Left column -->
        <div class="md:w-7/12 flex flex-col gap-4 md:gap-5">
          <!-- Product Marketing -->
          <div class="bg-blue rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[220px] flex flex-col justify-end">
            <div class="flex-1 relative flex items-center justify-center mb-4">
              <img src="/use-cases/product-launches.webp" alt="Product launch visuals" class="w-full h-auto rounded-2xl object-cover shadow-lg" width="1024" height="768" />
            </div>
            <div>
              <h3 class="font-display text-2xl md:text-3xl text-blue-ink">Product Launches</h3>
              <p class="mt-2 text-base text-blue-ink leading-snug max-w-xs">
                Launch visuals, feature announcements & product shots
              </p>
            </div>
          </div>

          <!-- Two square cards side by side -->
          <div class="flex flex-col sm:flex-row gap-4 md:gap-5">
            <!-- Ad Creatives — square -->
            <div class="sm:w-[57%] bg-orange rounded-[24px] p-6 md:p-7 relative overflow-hidden flex flex-col justify-between aspect-square">
              <div class="flex-1 flex items-center justify-center mb-3">
                <img src="/use-cases/ad-creatives.webp" alt="Ad creative designs" class="w-[85%] h-auto drop-shadow-xl object-contain" width="664" height="534" />
              </div>
              <div>
                <h3 class="font-display text-xl md:text-2xl text-orange-ink">Ad Creatives</h3>
                <p class="mt-1 text-base text-orange-ink leading-snug">
                  High-converting ads for Facebook, Instagram & YouTube
                </p>
              </div>
            </div>

            <!-- Voiceover & Audio — square -->
            <div class="sm:w-[43%] bg-purple rounded-[24px] p-6 md:p-7 relative overflow-hidden flex flex-col aspect-square">
              <div class="relative z-10 mb-3">
                <h3 class="font-display text-xl md:text-2xl text-purple-ink">Voiceover & Audio</h3>
                <p class="mt-1 text-base text-purple-ink leading-snug">
                  AI narration & sound effects
                </p>
              </div>
              <div class="flex-1 relative flex items-center justify-center voice-viz">
                <!-- Animated bars visualizer -->
                <div class="voice-bars">
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Email Campaigns — tall right card -->
        <div class="md:w-5/12 bg-pink rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[340px] flex flex-col">
          <div>
            <h3 class="font-display text-2xl md:text-3xl text-pink-ink">Email Campaigns</h3>
          </div>
          <div class="flex-1 relative flex items-center justify-center my-4">
            <img src="/use-cases/email-campaign.webp" alt="Email campaign design" class="w-[120%] max-w-none h-auto drop-shadow-xl object-contain" width="409" height="499" />
          </div>
          <div>
            <p class="text-base text-pink-ink leading-snug max-w-xs">
              Headers, banners & visuals for personalized campaigns
            </p>
          </div>
        </div>
      </div>

      <!-- Block 3: Remotion Videos + Landing Pages -->
      <div class="flex flex-col md:flex-row gap-4 md:gap-5">

        <!-- Remotion Videos -->
        <div class="md:w-7/12 bg-charcoal rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <!-- Floating React icon -->
        <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
          <div class="w-12 h-12 rounded-xl bg-[#61DAFB]/20 backdrop-blur-sm flex items-center justify-center shadow-lg border border-[#61DAFB]/30">
            <svg class="w-7 h-7 text-[#61DAFB]" viewBox="-11.5 -10.232 23 20.463" fill="currentColor">
              <circle r="2.05"></circle>
              <g stroke="currentColor" fill="none" stroke-width="1">
                <ellipse rx="11" ry="4.2"></ellipse>
                <ellipse rx="11" ry="4.2" transform="rotate(60)"></ellipse>
                <ellipse rx="11" ry="4.2" transform="rotate(120)"></ellipse>
              </g>
            </svg>
          </div>
        </div>
        <!-- Video -->
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <div class="w-full max-w-[520px] rounded-[12px] overflow-hidden">
            <video loop muted playsinline preload="none" class="w-full h-auto lazy-video">
              <source src="/use-cases/remotion-compose.webm" type="video/webm" />
            </video>
          </div>
        </div>
        <!-- Text -->
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 mt-1">
            <img src="/icons/remotion.svg" alt="Remotion" class="w-7 h-7" style="filter: brightness(0) invert(1);" />
          </div>
          <div>
            <h3 class="font-display text-2xl md:text-3xl text-white">Remotion Videos</h3>
            <p class="mt-2 text-base text-white/60 leading-snug max-w-md">
              Build full video productions with Remotion — insert AI-generated images, video clips & text-to-speech narration, all assembled programmatically
            </p>
          </div>
        </div>
      </div>

        <!-- Landing Pages -->
        <div class="md:w-5/12 bg-blue rounded-[24px] p-7 md:p-8 relative overflow-hidden min-h-[380px] md:min-h-[480px] flex flex-col justify-between">
        <div class="flex-1 relative flex items-center justify-center mb-4">
          <img src="/use-cases/landing-page.webp" alt="AI-generated landing page" class="w-full h-auto drop-shadow-xl object-contain" width="743" height="551" />
        </div>
        <!-- Text -->
        <div>
          <h3 class="font-display text-2xl md:text-3xl text-blue-ink">Landing Pages</h3>
          <p class="mt-2 text-base text-blue-ink leading-snug max-w-xs">
            Generate complete landing pages with AI imagery, copy & design — ship faster than ever
          </p>
        </div>
        </div>
      </div>

    </div>
  </div>
</section>

