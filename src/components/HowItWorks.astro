---
import IterationAnimation from './IterationAnimation.astro';

const steps = [
  {
    number: '01',
    title: 'Connect to Claude',
    description: 'Connect our plugin creative-claw@plugins. This installs the MCP and Skills for Claude — instant access to every top AI model.',
    image: '/how-it-works/claude-connections.png',
    bg: 'bg-coral',
  },
  {
    number: '02',
    title: 'Describe What You Need',
    description: 'Tell Claude what you want in plain language. Our built-in skills guide Claude to pick the right model, craft the perfect prompt, and generate multiple variants — so it can pick the best one for you.',
    custom: 'typing-demo',
    bg: 'bg-pink/30',
  },
  {
    number: '03',
    title: 'Claude Iterates to Perfection',
    description: 'Claude generates multiple options across different models, compares them, removes backgrounds, adds voiceover, composes Remotion videos — and delivers studio-quality assets ready for every platform.',
    custom: 'iteration-demo',
    bg: 'bg-orange/30',
  },
  {
    number: '04',
    title: 'Save Brand Assets & Reuse',
    description: 'Save your brand colors, fonts, logos, and style guidelines as reusable assets. Every future generation stays on-brand automatically — no more one-off prompting. Your brand DNA is baked in.',
    custom: 'brand-library',
    bg: 'bg-purple/30',
  },
];
---

<section id="how-it-works" class="py-20 md:py-28 px-6">
  <div class="mx-auto max-w-[1200px]">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal text-center">
      How CreativeClaw Works
    </h2>

    <div class="mt-16 space-y-20 md:space-y-28">
      {steps.map((step, i) => (
        <div class={`grid md:grid-cols-2 gap-10 md:gap-16 items-center ${i % 2 === 1 ? 'md:direction-rtl' : ''}`}>
          <!-- Image -->
          <div class={`${i % 2 === 1 ? 'md:order-2' : ''}`}>
            <div class={`${step.bg} rounded-[20px] aspect-[4/3] relative overflow-hidden`}>
              {step.image ? (
                <img src={step.image} alt={step.title} class="absolute bottom-0 right-0 w-full" />
              ) : step.custom === 'typing-demo' ? (
                <div class="absolute inset-0 flex items-center justify-center p-6 md:p-8">
                  <div class="bg-surface rounded-[20px] shadow-2xl w-full max-w-md border border-cream-dark/40">
                    <!-- Input area -->
                    <div class="p-4 md:p-5 min-h-[72px] text-left">
                      <span id="hiw-typing" class="text-sm md:text-base text-charcoal leading-relaxed"></span><span id="hiw-cursor" class="inline-block w-[2px] h-4 bg-charcoal/60 align-middle ml-0.5 animate-pulse"></span>
                    </div>
                    <!-- Bottom bar -->
                    <div class="px-4 md:px-5 pb-3 md:pb-4 flex items-center justify-between">
                      <div class="flex items-center gap-2">
                        <div class="flex items-center gap-1.5 border border-cream-dark/50 rounded-full px-2.5 py-1">
                          <svg class="w-3.5 h-3.5 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                          </svg>
                          <span class="text-xs text-charcoal">Brand assets</span>
                        </div>
                        <span class="text-lg text-charcoal-light/40 leading-none">+</span>
                      </div>
                      <button id="hiw-send-btn" class="bg-cream-dark/50 text-charcoal-light/50 rounded-xl px-4 py-2 text-xs font-semibold flex items-center gap-1.5 transition-all duration-300 cursor-default">
                        <span>Let's go</span>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              ) : step.custom === 'iteration-demo' ? (
                <IterationAnimation />
              ) : step.custom === 'brand-library' ? (
                <div id="brand-library" class="absolute inset-0 p-3 md:p-5">
                  {/* Floating abstract shapes */}
                  <div class="bl-shape absolute top-[4%] left-[8%] w-12 h-12 rounded-full bg-gradient-to-br from-[#00704A]/40 to-[#D4E9E2]/60 blur-[1px] opacity-0"></div>
                  <div class="bl-shape absolute top-[8%] right-[10%] w-8 h-8 rounded-lg rotate-45 bg-gradient-to-br from-[#CBA258]/50 to-[#E8D5A8]/40 opacity-0"></div>
                  <div class="bl-shape absolute bottom-[10%] left-[6%] w-7 h-7 rounded-full bg-gradient-to-br from-[#1E3932]/30 to-[#00704A]/40 opacity-0"></div>
                  <div class="bl-shape absolute bottom-[6%] right-[7%] w-10 h-10 rounded-2xl rotate-12 bg-gradient-to-br from-[#D4E9E2]/50 to-[#00704A]/20 blur-[1px] opacity-0"></div>
                  <div class="bl-shape absolute top-[45%] left-[3%] w-5 h-5 rounded-full bg-[#CBA258]/30 opacity-0"></div>
                  <div class="bl-shape absolute top-[3%] left-[42%] w-4 h-4 rounded-md rotate-[30deg] bg-[#1E3932]/20 opacity-0"></div>

                  {/* Claude input box — positioned at top */}
                  <div class="absolute top-3 left-1/2 -translate-x-1/2 bg-surface/95 backdrop-blur-sm rounded-[10px] px-3 py-2 shadow-lg w-[85%] max-w-[300px] border border-cream-dark/30 z-10">
                    <div class="flex items-start gap-2">
                      <img src="/icons/claude.svg" alt="Claude" class="w-4 h-4 mt-0.5 shrink-0" />
                      <p class="text-[10px] leading-[1.5] text-charcoal/80">Save as brand assets: logo <span class="font-semibold text-charcoal">starbucks-logo.svg</span>, font <span class="font-semibold text-charcoal">Sodo Sans</span>, colors <span class="font-mono text-[9px] px-0.5 rounded bg-[#00704A]/10 text-[#00704A]">#00704A</span> <span class="font-mono text-[9px] px-0.5 rounded bg-[#1E3932]/10 text-[#1E3932]">#1E3932</span> <span class="font-mono text-[9px] px-0.5 rounded bg-[#CBA258]/10 text-[#CBA258]">#CBA258</span></p>
                    </div>
                  </div>

                  {/* Brand card — centered vertically, nudged down */}
                  <div id="bl-card" class="absolute top-[30%] left-1/2 -translate-x-1/2 bg-surface/95 backdrop-blur-sm rounded-[12px] p-3 md:p-4 shadow-xl w-[75%] max-w-[260px] border border-cream-dark/30 z-10 opacity-0">
                    <div class="flex items-center gap-2 mb-2">
                      <img src="/on-brand/starbucks-logo.png" alt="Starbucks" class="h-6 object-contain" />
                      <span class="text-[9px] uppercase tracking-widest text-charcoal-light/60 font-semibold">Brand Kit</span>
                    </div>
                    <div class="flex gap-1.5 mb-2">
                      <div class="bl-swatch w-7 h-7 rounded-md shadow-sm opacity-0 scale-0" style="background-color: #00704A;"></div>
                      <div class="bl-swatch w-7 h-7 rounded-md shadow-sm opacity-0 scale-0" style="background-color: #1E3932;"></div>
                      <div class="bl-swatch w-7 h-7 rounded-md shadow-sm opacity-0 scale-0" style="background-color: #D4E9E2;"></div>
                      <div class="bl-swatch w-7 h-7 rounded-md shadow-sm opacity-0 scale-0" style="background-color: #CBA258;"></div>
                    </div>
                    <div id="bl-font" class="flex items-center gap-1.5 mb-2 opacity-0">
                      <span class="text-[10px] font-semibold" style="color: #1E3932; font-family: 'Georgia', serif;">Sodo Sans</span>
                      <span class="text-[9px] text-charcoal-light/50">Aa</span>
                      <div class="flex-1 flex gap-1">
                        <div class="h-1.5 flex-1 rounded-full bg-[#D4E9E2]"></div>
                        <div class="h-1.5 w-5 rounded-full bg-[#D4E9E2]/60"></div>
                      </div>
                    </div>
                    <div id="bl-saved" class="flex items-center gap-1 text-[#00704A] opacity-0">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                      <span class="text-[10px] font-semibold">Saved & reusable</span>
                    </div>
                  </div>
                </div>
              ) : (
                <span class="absolute inset-0 flex items-center justify-center text-charcoal/30 font-semibold">{step.placeholder}</span>
              )}
            </div>
          </div>
          <!-- Text -->
          <div class={`${i % 2 === 1 ? 'md:order-1' : ''}`}>
            <span class="font-mono text-sm text-coral font-semibold">{step.number}</span>
            <h3 class="mt-3 font-semibold text-xl md:text-[1.625rem] leading-[1.2] tracking-[-0.01em] text-charcoal">
              {step.title}
            </h3>
            <p class="mt-4 text-base md:text-lg text-charcoal-light leading-relaxed">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const PROMPT = "Create an Instagram Reel, a YouTube video, and a Facebook post for our spring beauty launch. Use our brand colors and keep it on-brand.";

  function runTypingLoop() {
    const typingEl = document.getElementById('hiw-typing');
    const cursorEl = document.getElementById('hiw-cursor');
    const sendBtn = document.getElementById('hiw-send-btn');

    if (!typingEl || !sendBtn || !cursorEl) return;

    function resetState() {
      typingEl.textContent = '';
      cursorEl.style.display = '';
      sendBtn.style.transform = '';
      sendBtn.classList.remove('bg-claude-orange', 'text-white', 'cursor-pointer');
      sendBtn.classList.add('bg-cream-dark/50', 'text-charcoal-light/50', 'cursor-default');
    }

    function animate() {
      resetState();
      const tl = gsap.timeline({
        onComplete: () => {
          setTimeout(animate, 6000);
        },
      });

      // Phase 1: Typing
      let charIndex = 0;
      tl.to({}, {
        duration: PROMPT.length * 0.028,
        onUpdate: function() {
          const progress = this.progress();
          const newIndex = Math.floor(progress * PROMPT.length);
          if (newIndex > charIndex) {
            charIndex = newIndex;
            typingEl.textContent = PROMPT.slice(0, charIndex);
          }
        },
        onComplete: () => {
          typingEl.textContent = PROMPT;
        },
        ease: 'none',
      });

      // Phase 2: Button activates
      tl.to(sendBtn, {
        duration: 0.3,
        onStart: () => {
          sendBtn.classList.remove('bg-cream-dark/50', 'text-charcoal-light/50', 'cursor-default');
          sendBtn.classList.add('bg-claude-orange', 'text-white', 'cursor-pointer');
        },
        ease: 'power2.out',
      }, '+=0.3');

      // Phase 3: Button press
      tl.to(sendBtn, { scale: 0.93, duration: 0.12, ease: 'power2.in' }, '+=0.4');
      tl.to(sendBtn, {
        scale: 1,
        duration: 0.15,
        ease: 'power2.out',
        onComplete: () => {
          cursorEl.style.display = 'none';
        },
      });
    }

    // Start immediately, loop forever
    animate();
  }

  function runBrandLibrary() {
    const container = document.getElementById('brand-library');
    if (!container) return;

    const shapes = container.querySelectorAll('.bl-shape');
    const card = document.getElementById('bl-card');
    const swatches = container.querySelectorAll('.bl-swatch');
    const font = document.getElementById('bl-font');
    const saved = document.getElementById('bl-saved');

    if (!card || !font || !saved) return;

    // Fade in shapes with stagger
    gsap.to(shapes, {
      opacity: 1,
      duration: 0.6,
      stagger: 0.15,
      ease: 'power2.out',
    });

    // Float shapes forever
    shapes.forEach((shape, i) => {
      gsap.to(shape, {
        y: `+=${8 + i * 3}`,
        rotation: `+=${4 + i * 2}`,
        duration: 3 + i * 0.7,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: i * 0.3,
      });
    });

    // Card entrance
    gsap.to(card, {
      opacity: 1,
      y: 0,
      duration: 0.7,
      ease: 'back.out(1.4)',
      delay: 0.4,
    });
    gsap.set(card, { y: 20 });

    // Swatches pop in
    gsap.to(swatches, {
      opacity: 1,
      scale: 1,
      duration: 0.4,
      stagger: 0.12,
      ease: 'back.out(2)',
      delay: 0.9,
    });

    // Swatch subtle pulse loop
    swatches.forEach((swatch, i) => {
      gsap.to(swatch, {
        scale: 1.08,
        boxShadow: '0 2px 12px rgba(0,0,0,0.15)',
        duration: 1.5,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: 1.5 + i * 0.4,
      });
    });

    // Font row fade in
    gsap.to(font, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out', delay: 1.5 });
    gsap.set(font, { x: -10 });

    // Saved indicator
    gsap.to(saved, { opacity: 1, duration: 0.5, ease: 'power2.out', delay: 1.9 });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { runTypingLoop(); runBrandLibrary(); });
  } else {
    runTypingLoop();
    runBrandLibrary();
  }
</script>
