<section id="waitlist" class="py-20 md:py-28 px-6 bg-coral">
  <div class="mx-auto max-w-[1200px] text-center">
    <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-white">
      Ready to Create?
    </h2>
    <p class="mt-5 text-lg text-white/80 max-w-xl mx-auto">
      Join the waitlist and be first to get access.
    </p>

    <!-- Waitlist form -->
    <form class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 max-w-lg mx-auto" onsubmit="return false;">
      <input
        type="email"
        placeholder="you@company.com"
        required
        class="w-full sm:flex-1 rounded-full bg-white/20 text-white placeholder:text-white/50 border border-white/30 px-6 py-4 text-base focus:outline-none focus:ring-2 focus:ring-white/50"
      />
      <button
        type="submit"
        class="w-full sm:w-auto rounded-full bg-charcoal text-white text-base font-semibold px-8 py-4 hover:bg-charcoal/90 transition-colors whitespace-nowrap"
      >
        Join Waitlist
      </button>
    </form>

    <p class="mt-6 text-sm text-white/50">
      No spam. We'll notify you when it's your turn.
    </p>
  </div>
</section>
