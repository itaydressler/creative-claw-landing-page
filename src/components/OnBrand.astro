<section class="py-20 md:py-28 px-6 bg-purple/20">
  <div class="mx-auto max-w-[1200px]">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <!-- Left: Visual -->
      <div class="relative">
        <!-- Brand card -->
        <div class="bg-surface rounded-[20px] p-8 shadow-lg">
          <div class="flex items-center gap-4 mb-6">
            <img src="/on-brand/starbucks-logo.png" alt="Starbucks logo" class="h-10 object-contain" />
          </div>
          <div class="flex gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg" style="background-color: #00704A;"></div>
            <div class="w-10 h-10 rounded-lg" style="background-color: #1E3932;"></div>
            <div class="w-10 h-10 rounded-lg" style="background-color: #D4E9E2;"></div>
            <div class="w-10 h-10 rounded-lg" style="background-color: #CBA258;"></div>
          </div>
          <div class="flex gap-2 items-center">
            <span class="text-xs font-semibold" style="color: #1E3932; font-family: 'Georgia', serif;">Sodo Sans</span>
            <span class="text-[10px] text-charcoal-light">Aa</span>
            <div class="h-3 w-16 rounded-full" style="background-color: #D4E9E2;"></div>
            <div class="h-3 w-10 rounded-full" style="background-color: #D4E9E2;"></div>
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex justify-center my-4">
          <svg class="w-6 h-6 text-charcoal-light animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </div>

        <!-- Generated outputs -->
        <div class="flex gap-3 items-end">
          <!-- IG Story — 9:16 -->
          <div class="relative group w-[35%] shrink-0">
            <img src="/on-brand/ig-story.png" alt="Starbucks IG Story" class="rounded-[12px] w-full aspect-[9/16] object-cover shadow-md group-hover:shadow-xl transition-shadow" />
            <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-sm p-1.5 rounded-full">
              <!-- Instagram icon -->
              <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </div>
          </div>
          <div class="flex flex-col gap-3 flex-1">
            <!-- YouTube — 16:9 -->
            <div class="relative group">
              <img src="/on-brand/youtube-thumb.png" alt="Starbucks YouTube Thumbnail" class="rounded-[12px] w-full aspect-video object-cover shadow-md group-hover:shadow-xl transition-shadow" />
              <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-sm p-1.5 rounded-full">
                <!-- YouTube icon -->
                <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.546 12 3.546 12 3.546s-7.505 0-9.377.504A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.504 9.376.504 9.376.504s7.505 0 9.377-.504a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </div>
            </div>
            <!-- Email — 5:2 -->
            <div class="relative group">
              <img src="/on-brand/email-header.png" alt="Starbucks Email Header" class="rounded-[12px] w-full aspect-[5/2] object-cover shadow-md group-hover:shadow-xl transition-shadow" />
              <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-sm p-1.5 rounded-full">
                <!-- Email icon -->
                <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Copy -->
      <div>
        <h2 class="font-display text-[2rem] md:text-[3.125rem] leading-[1] tracking-[-0.02em] text-charcoal">
          Always On Brand
        </h2>
        <p class="mt-6 text-lg text-charcoal-light leading-relaxed">
          Define your brand once. Every image, video, and asset Claude creates stays consistent — colors, fonts, style, tone. Your brand DNA is saved and reused across every generation.
        </p>
        <p class="mt-4 text-base text-charcoal-light leading-relaxed">
          Our MCP is packed with creative skills that guide Claude to generate multiple variants using different models, compare them side by side, and pick the best match — automatically. The result: studio-quality, on-brand assets every time. No more off-brand AI slop.
        </p>
        <a
          href="#waitlist"
          class="mt-8 inline-block rounded-full bg-charcoal text-white text-sm font-semibold px-8 py-3 hover:bg-charcoal/90 transition-colors"
        >
          Join the Beta
        </a>
      </div>
    </div>
  </div>
</section>
