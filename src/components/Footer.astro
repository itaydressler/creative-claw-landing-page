---
const quickLinks = [
  { label: 'Use Cases', href: '#use-cases' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Models', href: '#models' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];

const socialLinks = [
  { label: 'X / Twitter', href: '#' },
  { label: 'Discord', href: '#' },
];
---

<footer class="bg-charcoal text-white py-16 px-6">
  <div class="mx-auto max-w-[1200px]">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Col 1: Logo & tagline -->
      <div>
        <a href="/" class="font-display text-xl tracking-tight">
          Creative<span class="text-coral">Claw</span>
        </a>
        <p class="mt-4 text-sm text-white/50 leading-relaxed max-w-xs">
          The creative studio inside Claude. Generate on-brand images, video, audio, and more with every top AI model.
        </p>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h4 class="font-semibold text-sm text-white/60 uppercase tracking-wider mb-4">Quick Links</h4>
        <nav class="space-y-2">
          {quickLinks.map(link => (
            <a href={link.href} class="block text-sm text-white/70 hover:text-white transition-colors">{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Col 3: Social & Contact -->
      <div>
        <h4 class="font-semibold text-sm text-white/60 uppercase tracking-wider mb-4">Connect</h4>
        <nav class="space-y-2">
          {socialLinks.map(link => (
            <a href={link.href} class="block text-sm text-white/70 hover:text-white transition-colors">{link.label}</a>
          ))}
          <a href="mailto:hello@creativeclaw.co" class="block text-sm text-white/70 hover:text-white transition-colors">hello@creativeclaw.co</a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30">&copy; 2025 CreativeClaw. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-white/30 hover:text-white/60 transition-colors">Privacy Policy</a>
        <a href="#" class="text-xs text-white/30 hover:text-white/60 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
